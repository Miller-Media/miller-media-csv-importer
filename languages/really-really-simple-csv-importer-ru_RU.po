#: class-rscsv_import_post_helper.php:73
msgid "Provided Post ID not found."
msgstr "Указанный ID записи не найден."

#: class-rscsv_import_post_helper.php:179
#: class-rscsv_import_post_helper.php:199
#: class-rscsv_import_post_helper.php:220
#: class-rscsv_import_post_helper.php:235
#: class-rscsv_import_post_helper.php:251
msgid "WP_Post object is not set."
msgstr "Объект WP_Post не установлен."

#: class-rscsv_import_post_helper.php:364
msgid "Could not get remote file."
msgstr "Не удалось получить удаленный файл."

#: rs-csv-importer.php:47
msgid "Import CSV"
msgstr "Импорт CSV"

#: rs-csv-importer.php:57
msgid "Choose a CSV (.csv) file to upload, then click Upload file and import."
msgstr "Выберите CSV-файл (.csv) для загрузки, затем нажмите Загрузить файл и импортировать."

#: rs-csv-importer.php:58
msgid "Excel-style CSV file is unconventional and not recommended. LibreOffice has enough export options and recommended for most users."
msgstr "CSV-файл в стиле Excel нестандартен и не рекомендуется. LibreOffice имеет достаточно опций экспорта и рекомендуется для большинства пользователей."

#: rs-csv-importer.php:59
msgid "Requirements:"
msgstr "Требования:"

#: rs-csv-importer.php:61
msgid "Select UTF-8 as charset."
msgstr "Выберите UTF-8 в качестве кодировки."

#: rs-csv-importer.php:62
msgid "You must use field delimiter as \"%s\""
msgstr "Вы должны использовать \"%s\" в качестве разделителя полей"

#: rs-csv-importer.php:63
msgid "You must quote all text cells."
msgstr "Вы должны заключить все текстовые ячейки в кавычки."

#: rs-csv-importer.php:65
msgid "Download example CSV files:"
msgstr "Скачать примеры CSV-файлов:"

#: rs-csv-importer.php:66
msgid "csv"
msgstr "csv"

#: rs-csv-importer.php:67
msgid "ods"
msgstr "ods"

#: rs-csv-importer.php:68
msgid "(OpenDocument Spreadsheet file format for LibreOffice. Please export as csv before import)"
msgstr "(Формат файла электронной таблицы OpenDocument для LibreOffice. Пожалуйста, экспортируйте в формат csv перед импортом)"

#: rs-csv-importer.php:78 rs-csv-importer.php:82
msgid "Sorry, there has been an error."
msgstr "Извините, произошла ошибка."

#: rs-csv-importer.php:83
msgid "The export file could not be found at <code>%s</code>. It is likely that this was caused by a permissions problem."
msgstr "Файл экспорта не найден по адресу <code>%s</code>. Вероятно, это вызвано проблемой с правами доступа."

#: rs-csv-importer.php:148
msgid "Failed to open file."
msgstr "Не удалось открыть файл."

#: rs-csv-importer.php:174
msgid "Invalid post type \"%s\"."
msgstr "Недопустимый тип записи \"%s\"."

#: rs-csv-importer.php:177
msgid "Note: Please include post_type value if that is possible."
msgstr "Примечание: Пожалуйста, укажите значение post_type, если это возможно."

#: rs-csv-importer.php:192
msgid "The post type value from your csv file does not match the existing data in your database. post_id: %d, post_type(csv): %s, post_type(db): %s"
msgstr "Значение типа записи из вашего csv-файла не соответствует существующим данным в вашей базе данных. post_id: %d, post_type(csv): %s, post_type(db): %s"

#: rs-csv-importer.php:367
msgid "Processing \"%s\" done."
msgstr "Обработка \"%s\" завершена."

#: rs-csv-importer.php:386
msgid "All Done."
msgstr "Все готово."

#: rs-csv-importer.php:419
msgid "CSV"
msgstr "CSV"

#: rs-csv-importer.php:419
msgid "Import posts, categories, tags, custom fields from simple csv file."
msgstr "Импорт записей, категорий, меток, пользовательских полей из простого csv-файла."
